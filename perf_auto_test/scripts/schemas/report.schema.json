{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "perf_auto_test report v1",
  "type": "object",
  "required": [
    "schema_version",
    "run",
    "processes",
    "incidents",
    "lifecycle_events",
    "bookmarks",
    "data_files"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "run": {
      "type": "object",
      "required": [
        "started_at",
        "ended_at",
        "duration_sec",
        "exit_code",
        "exit_reason",
        "device",
        "package",
        "config_effective"
      ],
      "properties": {
        "started_at": { "type": "string" },
        "ended_at": { "type": "string" },
        "duration_sec": { "type": "number" },
        "exit_code": { "type": "integer" },
        "exit_reason": { "type": "string" },
        "device": { "type": "object" },
        "package": { "type": "string" },
        "config_effective": { "type": "object" }
      }
    },
    "processes": {
      "type": "array",
      "items": { "$ref": "#/definitions/process" }
    },
    "incidents": {
      "type": "array",
      "items": { "$ref": "#/definitions/incident" }
    },
    "lifecycle_events": {
      "type": "array",
      "items": { "$ref": "#/definitions/lifecycle_event" }
    },
    "bookmarks": {
      "type": "array",
      "items": { "$ref": "#/definitions/bookmark" }
    },
    "data_files": {
      "type": "object",
      "required": ["cpu", "mem", "lifecycle"],
      "properties": {
        "cpu":       { "type": "array", "items": { "type": "string" } },
        "mem":       { "type": "array", "items": { "type": "string" } },
        "lifecycle": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "definitions": {
    "stats": {
      "type": ["object", "null"],
      "properties": {
        "mean":    { "type": "number" },
        "p50":     { "type": "number" },
        "p90":     { "type": "number" },
        "p95":     { "type": "number" },
        "max":     { "type": "number" },
        "samples": { "type": "integer" }
      }
    },
    "process": {
      "type": "object",
      "required": ["name", "uptime_ratio", "restart_count", "stats", "alerts"],
      "properties": {
        "name":           { "type": "string" },
        "first_seen_at":  { "type": ["string", "null"] },
        "last_seen_at":   { "type": ["string", "null"] },
        "uptime_ratio":   { "type": "number", "minimum": 0, "maximum": 1 },
        "restart_count":  { "type": "integer", "minimum": 0 },
        "stats": {
          "type": "object",
          "required": ["cpu_pct", "mem_pss_mb"],
          "properties": {
            "cpu_pct":     { "$ref": "#/definitions/stats" },
            "mem_pss_mb":  { "$ref": "#/definitions/stats" }
          }
        },
        "alerts": {
          "type": "object",
          "required": ["cpu", "mem"],
          "properties": {
            "cpu": { "type": "integer", "minimum": 0 },
            "mem": { "type": "integer", "minimum": 0 }
          }
        },
        "sample_failures": {
          "type": "object",
          "properties": {
            "cpu": { "type": "integer", "minimum": 0 },
            "mem": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "incident": {
      "type": "object",
      "required": ["id", "type", "process", "pid", "triggered_at", "threshold", "observed", "evidence"],
      "properties": {
        "id":            { "type": "string", "pattern": "^incident-\\d+$" },
        "type":          { "type": "string", "enum": ["cpu_threshold", "mem_threshold"] },
        "process":       { "type": "string" },
        "pid":           { "type": "integer" },
        "triggered_at":  { "type": "string" },
        "threshold":     { "type": "object" },
        "observed":      { "type": "object" },
        "evidence":      { "type": "object" }
      }
    },
    "lifecycle_event": {
      "type": "object",
      "required": ["timestamp", "process", "event"],
      "properties": {
        "timestamp": { "type": "string" },
        "process":   { "type": "string" },
        "event":     { "type": "string", "enum": ["new", "gone", "restart"] },
        "old_pid":   { "type": "integer" },
        "new_pid":   { "type": "integer" },
        "gap_sec":   { "type": "number" }
      }
    },
    "bookmark": {
      "type": "object",
      "required": ["timestamp", "label"],
      "properties": {
        "timestamp": { "type": "string" },
        "label":     { "type": "string" },
        "metadata":  { "type": "object" }
      }
    }
  }
}
